# BrickLogic Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# ====================
# DATABASE CONFIGURATION
# ====================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=web
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ====================
# APPLICATION SETTINGS
# ====================
APP_NAME=BrickLogic
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/bricklogic
APP_TIMEZONE=Asia/Karachi

# ====================
# SESSION & SECURITY
# ====================
SESSION_NAME=bricklogic_session
SESSION_TIMEOUT=3600

# ====================
# EMAIL CONFIGURATION (PHPMailer)
# ====================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@bricklogic.com
MAIL_FROM_NAME=BrickLogic

# ====================
# FILE UPLOAD SETTINGS
# ====================
UPLOAD_DIR=./Uploads/
MAX_UPLOAD_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp

# ====================
# LOGGING
# ====================
LOG_LEVEL=debug
LOG_PATH=./logs/

